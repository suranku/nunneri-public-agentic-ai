# Nunneri local API configuration.
# Copy to .env or export these variables in your shell. Do not commit real keys.

DATABASE_URL=postgresql://nunneri:nunneri@localhost:5432/nunneri

# Auth
# Set true only after configuring OIDC below.
AUTH_ENABLED=true
OIDC_ISSUER_URL=https://your-oidc-provider.example.com/realms/nunneri
OIDC_CLIENT_ID=nunneri
OIDC_CLIENT_SECRET=replace-me
OIDC_REDIRECT_URI=http://localhost:8000/auth/callback
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_TTL_S=86400
# Optional local bearer-token auth for development when OIDC is not configured.
# Open Graph Studio as /ui#token=<same value>.
NUNNERI_API_TOKEN=

# Local Ollama
OLLAMA_BASE=http://localhost:11434
OLLAMA_MAX_CONCURRENT=2
OLLAMA_QUEUE_TIMEOUT_S=300
OLLAMA_MAX_CONTEXT_TOKENS=6000

# Optional cloud model providers
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
